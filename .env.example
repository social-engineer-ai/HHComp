# ============================================
# Horizon Hobby Competition Platform — .env.example
# Copy to .env and fill in secrets.
# ============================================

# ---- AWS ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
AWS_DEFAULT_REGION=us-east-2

# ---- S3 ----
S3_BUCKET=hh-comp-2026-files-use2

# ---- Google OAuth client (for Gmail sending) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_ADDRESS=
GMAIL_SENDER_NAME=Gies Supply Chain Case Competition

# ---- Database ----
DATABASE_URL=postgresql://hhcomp:hhcomp_dev_password@localhost:5432/hhcomp?schema=public

# ---- App ----
NODE_ENV=development
APP_URL=http://localhost:3000
SESSION_SECRET=generate_with_openssl_rand_base64_32
NDA_HASH_SALT=generate_with_openssl_rand_base64_32

# ---- Grader ----
GRADER_URL=http://grader:8000
GRADER_SHARED_SECRET=generate_with_openssl_rand_base64_32

# ---- Competition settings (overridable via admin GUI at runtime) ----
COMPETITION_DEADLINE_ISO=2026-05-02T04:59:59Z
COMPETITION_GRACE_END_ISO=2026-05-02T07:00:00Z
